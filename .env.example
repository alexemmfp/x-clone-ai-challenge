# Copy to .env and fill in. Never commit .env. ASP.NET Core maps __ to nested config.

# --- PostgreSQL (used by docker-compose and the backend) ---
POSTGRES_USER=twitter
POSTGRES_PASSWORD=change-me-local-dev
POSTGRES_DB=twitterclone
POSTGRES_PORT=5432

# --- Backend connection string (Npgsql) ---
ConnectionStrings__Default=Host=localhost;Port=5432;Database=twitterclone;Username=twitter;Password=change-me-local-dev

# --- JWT auth ---
Jwt__Issuer=twitterclone
Jwt__Audience=twitterclone-web
Jwt__SigningKey=replace-with-32+char-random-secret-in-dev
Jwt__AccessTokenMinutes=15
Jwt__RefreshTokenDays=7

# --- Password hashing ---
Bcrypt__WorkFactor=11

# --- CORS (frontend dev origin) ---
Cors__AllowedOrigins=http://localhost:5173

# --- Frontend (Vite) ---
VITE_API_BASE_URL=http://localhost:8080
